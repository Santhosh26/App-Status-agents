{
  "name": "status-agent-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/target-api",
    "packages/agent",
    "packages/dashboard"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "deploy": "npm run deploy --workspaces --if-present",
    "dev:target": "npm run dev -w packages/target-api",
    "dev:agent": "npm run dev -w packages/agent",
    "dev:dashboard": "npm run dev -w packages/dashboard",
    "deploy:target": "npm run deploy -w packages/target-api",
    "deploy:agent": "npm run deploy -w packages/agent",
    "deploy:dashboard": "npm run deploy -w packages/dashboard"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
